{
  "name": "drawparty",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron electron/main.js\"",
    "electron:build": "next build && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && electron-builder",
    "electron:preview": "next build && electron electron/main.js"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.38.3",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fabric": "^7.2.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-pwa": "^2.0.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "svix": "^1.86.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/next-pwa": "^5.6.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^9.1.2",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^25.0.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.5"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.drawparty.app",
    "productName": "DrawParty",
    "files": [
      "electron/",
      ".next/standalone/**",
      ".next/static/**",
      "public/**"
    ],
    "asarUnpack": [
      ".next/standalone/**"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "mac": {
      "icon": "public/drawparty.png",
      "category": "public.app-category.games"
    },
    "win": {
      "icon": "public/drawparty.png",
      "target": "nsis"
    },
    "linux": {
      "icon": "public/drawparty.png",
      "target": "AppImage"
    }
  }
}
